# ===== App =====
ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# ===== Auth (MVP: simple API key) =====
# 生产环境必须改，Web UI 也要改 NEXT_PUBLIC_API_KEY
API_KEY=dev-key-change-me

# ===== LLM =====
# 默认模型；建议从便宜的开始测：deepseek/deepseek-chat
DEFAULT_MODEL=deepseek/deepseek-chat
FALLBACK_MODELS=["gpt-4o-mini","claude-3-5-haiku-20241022"]

# 至少填一个供应商 key (LiteLLM 支持 140+ 供应商)
# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI
# OPENAI_API_KEY=sk-xxx

# DeepSeek (推荐起步：便宜 + 质量好)
# DEEPSEEK_API_KEY=sk-xxx

# Gemini
# GEMINI_API_KEY=xxx

# 阿里通义
# DASHSCOPE_API_KEY=sk-xxx

# 月之暗面 Kimi
# MOONSHOT_API_KEY=sk-xxx

# 智谱 GLM
# ZAI_API_KEY=xxx

# ===== Agent 防失控 =====
MAX_STEPS=15
MAX_COST_USD=0.50

# ===== Database (后续启用) =====
# DATABASE_URL=postgresql+asyncpg://agent:agent@localhost:5432/agent
# REDIS_URL=redis://localhost:6379/0

# ===== Observability (后续启用 Langfuse) =====
# LANGFUSE_PUBLIC_KEY=pk-lf-xxx
# LANGFUSE_SECRET_KEY=sk-lf-xxx
# LANGFUSE_HOST=http://localhost:3001

# ===== Frontend =====
# 给前端用的（NEXT_PUBLIC_ 前缀会暴露到浏览器，仅 MVP 用）
NEXT_PUBLIC_API_KEY=dev-key-change-me
BACKEND_URL=http://localhost:8000

# ===== Web Lite 静态托管 =====
# True = api-server 自己 serve apps/web-lite/chat.html (MVP 方便)
# False = api-server 仅 API, 前端走 Caddy/Nginx/CDN (见 infra/Caddyfile)
SERVE_WEB_LITE=true
