{
  "name": "@custom-agent/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Custom Agent Platform",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit -p tsconfig.json",
    "example": "node --import tsx examples/quickstart.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "agent",
    "llm",
    "ai",
    "deepseek",
    "openai",
    "anthropic",
    "sse"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
