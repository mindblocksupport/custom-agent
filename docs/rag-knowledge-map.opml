      <outline text="双击 docs/rag-knowledge-map.xmind"/>
      <outline text="XMind 自动打开"/>
    </outline>
    <outline text="A.2 OPML 兜底">
      <outline text="老版本 XMind 用 docs/rag-knowledge-map.opml"/>
      <outline text="File → Import → OPML"/>
    </outline>
    <outline text="A.3 重新生成">
      <outline text="python3 scripts/mdtoxmind.py docs/rag-knowledge-map.md docs/rag-knowledge-map.xmind"/>
      <outline text="python3 scripts/mdtoopml.py docs/rag-knowledge-map.md docs/rag-knowledge-map.opml"/>
    </outline>
